# CASEDD environment: secrets and endpoint-specific settings only.
# Non-secret operational settings now belong in casedd.yaml.

# Active config file path
CASEDD_CONFIG=casedd.yaml

# Development-only overrides used by ./dev.sh
CASEDD_DEV_LOG_LEVEL=DEBUG
CASEDD_DEV_DEBUG_FRAME_LOGS=1
CASEDD_DEV_NO_FB=1
CASEDD_DEV_HTTP_PORT=18080
CASEDD_DEV_WS_PORT=18765
CASEDD_DEV_FORCE_PROD_ISOLATION=0

# Emergency local keyboard shutdown (ESC or Q): enabled by default.
# Optional override for non-standard test paths or constrained environments.
CASEDD_EMERGENCY_EXIT_KEYS=1
CASEDD_EMERGENCY_INPUT_GLOB=/dev/input/event*

# Endpoint-specific service URLs
CASEDD_OLLAMA_API_BASE=http://localhost:11434
CASEDD_INVOKEAI_BASE_URL=http://localhost:9090
CASEDD_PLEX_BASE_URL=http://localhost:32400
CASEDD_PIHOLE_BASE_URL=http://pi.hole
CASEDD_RADARR_BASE_URL=
CASEDD_SONARR_BASE_URL=
CASEDD_NZBGET_URL=http://localhost:6789

# OS package update polling
CASEDD_OS_UPDATES_INTERVAL=900
CASEDD_OS_UPDATES_MANAGER=auto

# Weather location overrides (optional)
CASEDD_WEATHER_LAT=
CASEDD_WEATHER_LON=
CASEDD_WEATHER_ZIPCODE=

# Secrets / credentials / tokens
CASEDD_NASA_API_KEY=
CASEDD_PUSHOVER_WEBHOOK_URL=
CASEDD_API_KEY=
CASEDD_API_BASIC_USER=
CASEDD_API_BASIC_PASSWORD=
CASEDD_INVOKEAI_API_TOKEN=
CASEDD_PLEX_TOKEN=
CASEDD_PIHOLE_API_TOKEN=
CASEDD_PIHOLE_PASSWORD=
CASEDD_PIHOLE_SESSION_SID=
CASEDD_RADARR_API_KEY=
CASEDD_SONARR_API_KEY=
CASEDD_NZBGET_USERNAME=
CASEDD_NZBGET_PASSWORD=

# Synology DSM credentials (optional: leave blank to disable synology getter)
CASEDD_SYNOLOGY_HOST=
CASEDD_SYNOLOGY_PORT=5000
CASEDD_SYNOLOGY_USERNAME=
CASEDD_SYNOLOGY_PASSWORD=
CASEDD_SYNOLOGY_VERIFY_SSL=true
CASEDD_SYNOLOGY_STRIP_DOMAIN_HOSTNAME=true

# TrueNAS credentials (optional: leave blank to disable truenas getter)
CASEDD_TRUENAS_HOST=
CASEDD_TRUENAS_PORT=80
CASEDD_TRUENAS_API_KEY=
CASEDD_TRUENAS_VERIFY_SSL=true
CASEDD_TRUENAS_STRIP_DOMAIN_HOSTNAME=true

# Tuya Smart Home Devices (read-only polling of sensors and smart plugs)
# Configure devices in casedd.yaml, not here. See docs/tuya_setup.md for details.
# Device List Format (in casedd.yaml):
#   tuya_devices:
#     - device_id: "your_device_id_here"
#       local_key: "your_local_key_here"
#       device_type: "sensor"  # or "plug"
#       ip_address: "192.168.1.100"  # optional, for faster local polling
# Polling interval (seconds):
# CASEDD_TUYA_INTERVAL=10.0
