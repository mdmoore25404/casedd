# ============================================================
# CASEDD Environment Configuration
# Copy this file to .env and edit for your environment.
# All values shown are the defaults used when unset.
# ============================================================

# ---------- Logging ----------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
CASEDD_LOG_LEVEL=INFO

# ---------- Display / Framebuffer ----------
# Set to 1 to disable framebuffer output entirely (dev mode / no hardware)
CASEDD_NO_FB=0

# Framebuffer device. Waveshare 5" USB display typically appears as /dev/fb1
CASEDD_FB_DEVICE=/dev/fb1

# ---------- Network ports ----------
# WebSocket server port (live image push to browser)
CASEDD_WS_PORT=8765

# HTTP viewer port (serves web page + /image endpoint + /docs)
CASEDD_HTTP_PORT=8080

# Default browser page background for the web viewer (non-framebuffer area)
# Accepts CSS color strings (e.g. #0d0f12, #000000, rgb(12,12,12)).
CASEDD_VIEWER_BG=#0d0f12

# ---------- Unix socket ----------
# Path for JSON data-write socket. Directory is created if absent.
CASEDD_SOCKET_PATH=/run/casedd/casedd.sock

# ---------- Template ----------
# Name of the active .casedd template (no extension, relative to templates/)
CASEDD_TEMPLATE=system_stats

# Optional comma-separated template rotation list.
# Example: CASEDD_TEMPLATE_ROTATION=fans,slideshow,system_stats
CASEDD_TEMPLATE_ROTATION=

# Seconds per template in rotation mode
CASEDD_TEMPLATE_ROTATION_INTERVAL=30

# ---------- Rendering ----------
# Global render rate in Hz (frames per second)
CASEDD_REFRESH_RATE=2.0

# ---------- Speedtest (Ookla CLI) ----------
# Poll interval in seconds (default: 30 minutes)
CASEDD_SPEEDTEST_INTERVAL=1800

# Ookla speedtest binary name/path
CASEDD_SPEEDTEST_BINARY=speedtest

# Optional fixed Ookla server ID (empty = auto-select)
# Example: 14229 (Frontier, Ashburn VA)
CASEDD_SPEEDTEST_SERVER_ID=

# Advertised ISP plan speeds in Mb/s (used for % of plan gauges)
CASEDD_SPEEDTEST_ADVERTISED_DOWN_MBPS=2000
CASEDD_SPEEDTEST_ADVERTISED_UP_MBPS=200

# Optional effective local ceilings in Mb/s for host-limited links
# (when set, % gauges can target local achievable speeds instead of WAN plan max)
CASEDD_SPEEDTEST_REFERENCE_DOWN_MBPS=
CASEDD_SPEEDTEST_REFERENCE_UP_MBPS=

# Threshold ratios for status classification (good/marginal/critical)
CASEDD_SPEEDTEST_MARGINAL_RATIO=0.9
CASEDD_SPEEDTEST_CRITICAL_RATIO=0.7

# ---------- Ollama API ----------
# Local Ollama API port (dev + compose interpolation default)
CASEDD_OLLAMA_PORT=11434

# HTTP API base URL (do not require local `ollama` CLI)
CASEDD_OLLAMA_API_BASE=http://localhost:11434

# Poll interval and timeout (seconds)
CASEDD_OLLAMA_INTERVAL=10
CASEDD_OLLAMA_TIMEOUT=3

# Canvas dimensions — should match your display
CASEDD_WIDTH=800
CASEDD_HEIGHT=480

# ---------- Config file ----------
# Path to optional casedd.yaml for settings that override these env vars
CASEDD_CONFIG=casedd.yaml
