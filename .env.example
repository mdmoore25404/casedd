# ============================================================
# CASEDD Environment Configuration
# Copy this file to .env and edit for your environment.
# All values shown are the defaults used when unset.
# ============================================================

# ---------- Logging ----------
# Log level: NONE | DEBUG | INFO | WARNING | ERROR | CRITICAL
CASEDD_LOG_LEVEL=INFO

# Enable hot-path per-frame renderer debug logs (off by default).
CASEDD_DEBUG_FRAME_LOGS=0

# Development-only overrides used by `./dev.sh`.
# These are ignored by the production systemd unit.
CASEDD_DEV_LOG_LEVEL=DEBUG
CASEDD_DEV_DEBUG_FRAME_LOGS=1
CASEDD_DEV_NO_FB=1
CASEDD_DEV_HTTP_PORT=18080
CASEDD_DEV_WS_PORT=18765

# Force dev isolation behavior even when the production systemd service is
# not installed. Useful for testing the dev/prod collision guardrails.
CASEDD_DEV_FORCE_PROD_ISOLATION=0

# ---------- Display / Framebuffer ----------
# Set to 1 to disable framebuffer output entirely (dev mode / no hardware)
CASEDD_NO_FB=0

# Framebuffer device. Default to /dev/fb0; set to your attached fb device.
CASEDD_FB_DEVICE=/dev/fb0

# Optional global framebuffer rotation (0, 90, 180, 270)
CASEDD_FB_ROTATION=0

# ---------- Network ports ----------
# WebSocket server port (live image push to browser)
CASEDD_WS_PORT=8765

# HTTP viewer port (serves web page + /image endpoint + /docs)
CASEDD_HTTP_PORT=8080

# Advanced app Vite dev server port (used by ./dev.sh and /app redirect)
CASEDD_APP_PORT=5173

# Host-mapped advanced app port used in Docker Compose (/app will redirect here)
CASEDD_DOCKER_APP_PORT=15173

# Default browser page background for the web viewer (non-framebuffer area)
# Accepts CSS color strings (e.g. #0d0f12, #000000, rgb(12,12,12)).
CASEDD_VIEWER_BG=#0d0f12

# ---------- Unix socket ----------
# Path for JSON data-write socket. Directory is created if absent.
CASEDD_SOCKET_PATH=/run/casedd/casedd.sock

# ---------- Template ----------
# Name of the active .casedd template (no extension, relative to templates/)
CASEDD_TEMPLATE=system_stats

# Show a startup splash for this many seconds before normal rendering begins.
# This gives getters time to populate initial values.
CASEDD_STARTUP_FRAME_SECONDS=5

# Optional comma-separated template rotation list.
# Example: CASEDD_TEMPLATE_ROTATION=fans,slideshow,system_stats
CASEDD_TEMPLATE_ROTATION=

# Seconds per template in rotation mode
CASEDD_TEMPLATE_ROTATION_INTERVAL=30

# Optional comma-separated namespaces that should always be collected
# regardless of active template needs. Example: cpu,memory,system
CASEDD_ALWAYS_COLLECT_PREFIXES=

# Global test mode toggle. When enabled, all getters are disabled and only
# external pushes/simulation data feed the display.
CASEDD_TEST_MODE=0

# ---------- Rendering ----------
# Global render rate in Hz (frames per second)
CASEDD_REFRESH_RATE=2.0

# ---------- Speedtest (Ookla CLI) ----------
# Poll interval in seconds (default: 30 minutes)
CASEDD_SPEEDTEST_INTERVAL=1800

# Optional delay before the first speedtest run after startup (seconds).
# Set >0 in production to avoid startup-time speedtest load.
CASEDD_SPEEDTEST_STARTUP_DELAY=0

# Ookla speedtest binary name/path
CASEDD_SPEEDTEST_BINARY=speedtest

# Optional fixed Ookla server ID (empty = auto-select)
# Example: 14229 (Frontier, Ashburn VA)
CASEDD_SPEEDTEST_SERVER_ID=

# Advertised ISP plan speeds in Mb/s (used for % of plan gauges)
CASEDD_SPEEDTEST_ADVERTISED_DOWN_MBPS=2000
CASEDD_SPEEDTEST_ADVERTISED_UP_MBPS=200

# Optional effective local ceilings in Mb/s for host-limited links
# (when set, % gauges can target local achievable speeds instead of WAN plan max)
CASEDD_SPEEDTEST_REFERENCE_DOWN_MBPS=
CASEDD_SPEEDTEST_REFERENCE_UP_MBPS=

# Threshold ratios for status classification (good/marginal/critical)
CASEDD_SPEEDTEST_MARGINAL_RATIO=0.9
CASEDD_SPEEDTEST_CRITICAL_RATIO=0.7

# ---------- Ollama API ----------
# Local Ollama API port (dev + compose interpolation default)
CASEDD_OLLAMA_PORT=11434

# HTTP API base URL (do not require local `ollama` CLI)
CASEDD_OLLAMA_API_BASE=http://localhost:11434

# Poll interval and timeout (seconds)
CASEDD_OLLAMA_INTERVAL=10
CASEDD_OLLAMA_TIMEOUT=3

# ---------- Htop-style process getter ----------
# Poll interval in seconds and max rows shown by htop widget.
CASEDD_HTOP_INTERVAL=2
CASEDD_HTOP_MAX_ROWS=12

# ---------- Plex ----------
# Plex server base URL and token (Settings -> Account -> Plex Token).
CASEDD_PLEX_BASE_URL=http://localhost:32400
CASEDD_PLEX_TOKEN=

# Client metadata recommended by Plex API docs.
CASEDD_PLEX_CLIENT_IDENTIFIER=casedd
CASEDD_PLEX_PRODUCT=CASEDD

# Poll interval/timeout in seconds.
CASEDD_PLEX_INTERVAL=5
CASEDD_PLEX_TIMEOUT=4

# Set to 0 to allow self-signed TLS certs on HTTPS Plex hosts.
CASEDD_PLEX_VERIFY_TLS=1

# Maximum now-playing and recently-added rows to flatten/render.
CASEDD_PLEX_MAX_SESSIONS=6
CASEDD_PLEX_MAX_RECENT=6

# Optional privacy filter: redact matching media/library names.
# Example: CASEDD_PLEX_PRIVACY_FILTER_REGEX=(kids|private|family)
CASEDD_PLEX_PRIVACY_FILTER_REGEX=
# Optional explicit library-name filter (comma-separated, case-insensitive).
# Example: CASEDD_PLEX_PRIVACY_FILTER_LIBRARIES=Kids,Private,Family Vault
CASEDD_PLEX_PRIVACY_FILTER_LIBRARIES=
CASEDD_PLEX_PRIVACY_REDACTION_TEXT=[hidden]

# ---------- Weather ----------
# Provider: nws (official US NWS API) or open-meteo (external provider example).
CASEDD_WEATHER_PROVIDER=nws
CASEDD_WEATHER_INTERVAL=300

# Configure location via ZIP or explicit lat/lon.
CASEDD_WEATHER_ZIPCODE=20420
CASEDD_WEATHER_LAT=
CASEDD_WEATHER_LON=

# Required by NWS API policy; set to your own app/contact string for production.
CASEDD_WEATHER_USER_AGENT=CASEDD/0.2 (https://github.com/casedd/casedd)

# ---------- UPS ----------
# Optional custom command for UPS data collection. Leave empty to auto-detect
# apcaccess/upsc backends.
CASEDD_UPS_COMMAND=

# Poll interval for UPS getter in seconds
CASEDD_UPS_INTERVAL=5

# Target passed to `upsc` when using NUT backend
CASEDD_UPS_UPSC_TARGET=ups@localhost

# Canvas dimensions are auto-detected from the configured framebuffer device.
# If you need hard overrides, use `width` / `height` in `casedd.yaml`.

# ---------- Linux host metric path mapping ----------
# psutil procfs root. Keep /proc for normal host runs. In Docker Compose,
# this is set to /host/proc to read host-level process/system stats.
CASEDD_PROCFS_PATH=/proc

# ---------- Config file ----------
# Path to optional casedd.yaml for settings that override these env vars
CASEDD_CONFIG=casedd.yaml

# ---------- NASA APOD ----------
# API key for the NASA Astronomy Picture of the Day API.
# Get your free key at https://api.nasa.gov/
# Leave blank to use the demo key (limited to 30 req/hour/IP).
CASEDD_NASA_API_KEY=

# How often CASEDD checks for a new APOD (in seconds). The image only
# changes once per day; hourly polling is sufficient.
CASEDD_APOD_INTERVAL=3600

# Directory where downloaded APOD images are cached.
CASEDD_APOD_CACHE_DIR=/tmp/casedd-apod

# ---------- Update API auth / rate limiting ----------
# Optional shared secret for POST /api/update and POST /update.
CASEDD_API_KEY=

# Optional HTTP Basic Auth credentials for POST /api/update and POST /update.
# Set both together or leave both blank.
CASEDD_API_BASIC_USER=
CASEDD_API_BASIC_PASSWORD=

# Per-IP write limit for update requests. 0 disables rate limiting.
CASEDD_API_RATE_LIMIT=0

# ---------- Pushover Notifications ----------
# When set, CASEDD posts a JSON payload to this URL whenever a trigger rule
# with `notify: true` activates.  Create a webhook in your Pushover dashboard
# at https://pushover.net/dashboard and paste its unique URL here.
# Configure your webhook selectors to extract: {{title}} and {{message}}.
CASEDD_PUSHOVER_WEBHOOK_URL=
