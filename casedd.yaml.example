# CASEDD sample YAML configuration.
#
# This demonstrates template rotation, schedule windows, and data-driven
# trigger overrides. Environment variables still override any values here.

log_level: INFO
template: system_stats
refresh_rate: 2.0

# Core system getter poll intervals.
# High-cadence getters default to 2-5 s; slow-changing data can be relaxed.
# Use CASEDD_<NAME>_INTERVAL env vars or uncomment the lines below.
# cpu_interval: 2.0           # CASEDD_CPU_INTERVAL
# gpu_interval: 5.0           # CASEDD_GPU_INTERVAL
# memory_interval: 2.0        # CASEDD_MEMORY_INTERVAL
# disk_interval: 2.0          # CASEDD_DISK_INTERVAL
# network_interval: 2.0       # CASEDD_NETWORK_INTERVAL
# system_interval: 10.0       # CASEDD_SYSTEM_INTERVAL
# fans_interval: 3.0          # CASEDD_FANS_INTERVAL
# net_ports_interval: 5.0     # CASEDD_NET_PORTS_INTERVAL
# sysinfo_interval: 30.0      # CASEDD_SYSINFO_INTERVAL

# Speedtest cache persists the latest pushed/polled speedtest payload so a dev
# restart does not blank the speedtest dashboard until the next update arrives.
# Cache entries older than this max-age are ignored at startup.
# speedtest_cache_path: run/speedtest-cache.json
# speedtest_cache_max_age_hours: 8.0

# Ollama polling configuration.
# Detailed mode adds /api/version and /api/tags polling plus expanded
# ollama.running_<n> / ollama.model_<n> keys for local-AI dashboards.
# ollama_api_base: http://localhost:11434
# ollama_interval: 10.0
# ollama_timeout: 3.0
# ollama_detailed: false
# ollama_detail_max_models: 8

# OS package update polling (apt/dnf).
# Manager mode: auto|apt|dnf. In auto mode, apt is preferred when both exist.
# os_updates_interval: 900.0
# os_updates_manager: auto

# Sports scores and schedules from TheSportsDB (free, no registration needed).
# The free API key "123" allows basic queries; register at thesportsdb.com for
# premium access (more event history, higher rate limits).
# Team names must match TheSportsDB exactly (e.g. "Los Angeles Lakers", not "Lakers").
# Use the sport field to disambiguate when a search returns multiple teams
# (e.g. "West Virginia" matches both NCAA Football and NCAA Basketball).
#
# Enable templates sports_scores.casedd and sports_today.casedd once configured.
# sports_enabled: false
# sports_api_key: "123"              # CASEDD_SPORTS_API_KEY
# sports_interval: 300.0             # CASEDD_SPORTS_INTERVAL  (poll every 5 min)
# sports_timeout: 5.0                # CASEDD_SPORTS_TIMEOUT
# sports_max_teams: 10               # CASEDD_SPORTS_MAX_TEAMS
# sports_recent_window_hours: 48     # CASEDD_SPORTS_RECENT_WINDOW_HOURS
# sports_followed_teams:
#   - team: "Los Angeles Lakers"
#     sport: "Basketball"            # Optional: helps when search returns multiple teams
#   - team: "Washington Capitals"
#     sport: "Ice Hockey"
#   - team: "Washington Nationals"
#     sport: "Baseball"
#   - team: "Washington Commanders"
#     sport: "American Football"
#   - team: "West Virginia"
#     sport: "Basketball"            # NCAA Basketball
#   - team: "West Virginia"
#     sport: "American Football"     # NCAA Football

# Servarr polling configuration (Radarr/Sonarr).
# One-app setup: configure only Radarr or only Sonarr fields.
# Two-app setup: configure both pairs of base URL + API key.
# radarr_base_url: http://localhost:7878
# radarr_api_key: ""
# radarr_interval: 15.0
# radarr_timeout: 4.0
# radarr_calendar_days: 7
# radarr_verify_tls: true
# sonarr_base_url: http://localhost:8989
# sonarr_api_key: ""
# sonarr_interval: 15.0
# sonarr_timeout: 4.0
# sonarr_calendar_days: 7
# sonarr_verify_tls: true

# Framebuffer device.  Override when you have multiple /dev/fb* devices.
# fb_device: /dev/fb1

# Set to true to scan for a USB-connected framebuffer at startup.
# The first detected USB display is used when fb_device does not exist.
# Resolution is inherited from the display when width/height are not set.
# fb_auto_detect: false

# Disable framebuffer output entirely (HTTP/WebSocket viewers still work).
# no_fb: false

# Color of the border drawn around the display when a trigger is active.
# Any CSS color (hex, named, rgb()) is accepted.  Defaults to bright red.
# Use a different color if red is not accessible in your environment.
# trigger_border_color: "#dc1e1e"       # bright red (default)
# trigger_border_color: "#ff00ff"       # magenta / fuchsia
# trigger_border_color: "#ff8c00"       # dark orange

# Panel configuration.
# Each panel owns its rotation, schedule, and trigger rules.
# Panels that omit a setting inherit from the matching global fallback.
panels:
  - name: primary
    display_name: Physical Display

    # Rotation applies when no trigger or schedule rule is active.
    template_rotation_enabled: true
    template_rotation:
      - apod
      - nzbget_queue
      - system_stats
      - plex_dashboard
    template_rotation_interval: 30

    # Note: plex_dashboard includes template-level skip_if rules so it is
    # skipped automatically when there are no active/transcoding Plex sessions.

    # Local-time schedule windows (0=Mon ... 6=Sun).
    template_schedule:
      - template: slideshow
        start: "22:30"
        end: "06:30"
        days: [0, 1, 2, 3, 4, 5, 6]

    # Trigger rules have highest priority.
    # Multiple rules targeting the same template act as OR logic — any one
    # matching activates that template.  Use 'disabled: true' to suppress a
    # rule temporarily without deleting it.
    template_triggers:
      - source: cpu.percent
        operator: gte
        value: 90
        template: system_stats
        duration: 10
        hold_for: 20
        clear_operator: lte
        clear_value: 70
        cooldown: 30
        priority: 10
        # Send a Pushover notification when this trigger first activates.
        # Requires CASEDD_PUSHOVER_WEBHOOK_URL to be configured.
        notify: true
        notify_title: "High CPU Alert"
        notify_message: "CPU usage exceeded 90% — switched to system_stats view."

      # GPU OR group: any one of these three rules activates nvidia_detail.
      # Set disabled: true on individual rules to suppress a condition while
      # keeping the config in place (e.g. during development or testing).
      - source: nvidia.percent
        operator: gte
        value: 50
        template: nvidia_detail
        duration: 5
        hold_for: 30
        clear_operator: lt
        clear_value: 40
        cooldown: 60
        priority: 20
        notify: true
        notify_title: "GPU Load Alert"
        notify_message: "GPU utilisation exceeded 50%."

      - source: nvidia.memory_percent
        operator: gte
        # Raise this if you cache LLM models in VRAM — e.g. 97 when ~83% is
        # normal steady-state so the alert only fires on genuine pressure.
        value: 90
        template: nvidia_detail
        duration: 5
        hold_for: 30
        clear_operator: lt
        # Set clear_value above your normal idle VRAM usage (e.g. 88 if idle ~83%)
        # so the trigger view doesn't re-activate immediately after clearing.
        clear_value: 80
        cooldown: 60
        priority: 20
        notify: true
        notify_title: "GPU VRAM Alert"
        notify_message: "GPU VRAM usage exceeded 90%."
        # Uncomment to disable this rule without removing it:
        # disabled: true

      - source: nvidia.temperature
        operator: gte
        value: 80
        template: nvidia_detail
        duration: 5
        hold_for: 30
        clear_operator: lt
        clear_value: 70
        cooldown: 60
        priority: 20
        notify: true
        notify_title: "GPU Temperature Alert"
        notify_message: "GPU temperature exceeded 80°C."

      - source: fans.cpu.max_rpm
        operator: gte
        value: 1800
        template: fans
        duration: 5
        hold_for: 15
        clear_operator: lte
        clear_value: 1400
        cooldown: 30
        priority: 30

  - name: virtpanel
    display_name: Virtual Panel
    no_fb: true
    width: 1280
    height: 720
    template: system_stats

# Optional grid layout for the multi-panel web viewer.
# columns: number of CSS grid columns.
# cells:   panel names in left-to-right, top-to-bottom order.
#          Use "" (empty string) to leave a cell blank.
# When omitted, the viewer uses an auto-fit grid.
viewer_layout:
  columns: 2
  cells:
    - primary
    - virtpanel
