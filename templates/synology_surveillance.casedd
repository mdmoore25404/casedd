# synology_surveillance.casedd — Surveillance Station focused monitor

name: synology_surveillance
description: Surveillance Station focused view with camera snapshots and recorder status.
aspect_ratio: "5:3"
layout_mode: fit
background: "#0e1418"
refresh_rate: 1.0

grid:
  template_areas: |
    brand title title status
    cam1 cam1 cam2 cam2
    empty3 empty3 empty4 empty4
  columns: "0.9fr 1.1fr 1.1fr 1fr"
  rows: "0.56fr 1.22fr 1.22fr"

widgets:
  brand:
    type: panel
    background: "#162028"
    padding: 8
    grid:
      template_areas: |
        logo
      columns: "1fr"
      rows: "1fr"
    children_named:
      logo:
        type: image
        path: assets/synology/surveillance-station-logo.png
        scale: fit
        padding: [4, 6]

  title:
    type: panel
    background: "#162028"
    padding: [8, 10]
    grid:
      template_areas: |
        name version
        cams rec
      columns: "1fr 1fr"
      rows: "1fr 1fr"
    children_named:
      name:
        type: value
        label: Host
        source: synology.system.hostname
        color: "#9fe6c3"
        font_size: auto
        max_font_size: 40
      version:
        type: value
        label: DSM
        source: synology.system.version
        color: "#8ed9ff"
        font_size: auto
        max_font_size: 34
      cams:
        type: value
        label: Cameras
        source: synology.surveillance.camera_count
        precision: 0
        color: "#e8f2ff"
        font_size: auto
        max_font_size: 34
      rec:
        type: value
        label: Recording
        source: synology.surveillance.recording_count
        precision: 0
        color: "#ffd177"
        font_size: auto
        max_font_size: 34

  status:
    type: table
    label: Services + Cameras
    source: synology.surveillance.status.rows
    color: "#e8f2ff"
    background: "#162028"
    table_fit_text: false
    max_items: 12
    padding: [8, 10]

  cam1:
    type: image
    label: Camera 1
    source: synology.camera_1.snapshot_url
    scale: fill
    padding: [4, 4]

  cam2:
    type: image
    label: Camera 2
    source: synology.camera_2.snapshot_url
    scale: fill
    padding: [4, 4]

  empty3:
    type: text
    label: Camera 3
    content: no camera
    color: "#808b96"
    background: "#162028"
    font_size: auto
    padding: [4, 8]

  empty4:
    type: text
    label: Camera 4
    content: no camera
    color: "#808b96"
    background: "#162028"
    font_size: auto
    padding: [4, 8]
