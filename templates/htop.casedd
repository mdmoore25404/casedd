# htop.casedd — single-widget htop-like process table

name: htop
description: Single-panel process list sorted by CPU utilization.
width: 800
height: 480
background: "#0b1118"
refresh_rate: 2.0

grid:
  template_areas: |
    procs
  columns: 1fr
  rows: 1fr

widgets:
  procs:
    type: htop
    label: "Top Processes"
    source: htop.rows
    color: "#6ee786"
    background: "#101822"
    padding: [8, 10]
