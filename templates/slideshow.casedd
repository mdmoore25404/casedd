# slideshow.casedd — Full-screen image slideshow template
#
# Minimal reference for slideshow widget options.

name: slideshow
description: Fullscreen slideshow cycling images from assets/slideshow.
refresh_rate: 2.0

grid:
  template_areas: |
    slides
  columns: 1fr
  rows: 1fr

background: "#000000"

widgets:
  slides:
    type: slideshow
    paths:
      - assets/slideshow
    interval: 5.0
    transition: fade
    scale: fill
