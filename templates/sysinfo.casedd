# sysinfo.casedd — neofetch-style system information panel

name: sysinfo
description: System information dashboard in neofetch style.
aspect_ratio: "5:3"
layout_mode: fit
background: "#0b1118"
refresh_rate: 30.0

grid:
  template_areas: |
    info
  columns: 1fr
  rows: 1fr

widgets:
  info:
    type: sysinfo
    label: "System Info"
    source: sysinfo.rows
    font_size: "auto"
    color: "#60e6a5"
    background: "#101822"
    padding: [8, 10]
